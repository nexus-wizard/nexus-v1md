# Nexus-1MD Git Ignore

# Dependency directories
node_modules/
jspm_packages/

# Authentication & Session Data (CRITICAL: Do NOT push these!)
auth_info_baileys/
session/*
!session/.gitkeep
creds.json
creds/
auth/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Operating System Files
.DS_Store
Thumbs.db
desktop.ini

# Temporary / Downloaded Files
database/
temp/
tmp/
downloads/
* .download
* .cache

# IDE / Editor Files
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Build / Backup
dist/
build/
*.bak
*.tmp
